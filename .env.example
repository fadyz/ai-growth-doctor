APP_NAME="AI Growth Doctor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_growth_doctor
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Demo protection for hosted judge demo
DEMO_AUTH_ENABLED=false
DEMO_AUTH_USER=judge
DEMO_AUTH_PASSWORD=change-me
DEMO_AUTH_REALM="AI Growth Doctor Demo"

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AI_PROVIDER=qwen
AI_OUTPUT_LANGUAGE=English

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

SUMOPOD_API_KEY=
SUMOPOD_BASE_URL=https://ai.sumopod.com
SUMOPOD_MODEL=gpt-5.4-nano

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
